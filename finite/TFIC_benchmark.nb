Cell[CellGroupData[{
Cell["Transverse Field Ising Chain - Exact Solution", "Section",
 CellChangeTimes->{{3.9823838396254807`*^9, 
  3.9823838422830753`*^9}},ExpressionUUID->"3c7ba1ed-a15e-4e5c-b87c-\
aecb7b2f62c3"],

Cell[CellGroupData[{

Cell["Functions", "Subsection",
 CellChangeTimes->{{3.9823838473747377`*^9, 
  3.98238384899714*^9}},ExpressionUUID->"5b2b0088-d04c-4928-b7d9-\
347a835ad69b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"--", 
    RowBox[{"--", 
     RowBox[{"--", 
      RowBox[{"--", 
       RowBox[{"--", 
        RowBox[{"--", 
         RowBox[{"--", 
          RowBox[{"--", 
           RowBox[{"--", 
            RowBox[{"--", 
             RowBox[{"--", "-"}]}]}]}]}]}]}]}]}]}]}], "*)"}], "\n", 
  RowBox[{"(*", 
   RowBox[{"AFM", "+", 
    RowBox[{"PBC", " ", "requires", " ", "even", " ", "sites"}]}], "*)"}], 
  "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"validLQ", "[", "L_", "]"}], ":=", 
    RowBox[{
     RowBox[{"EvenQ", "[", "L", "]"}], "&&", 
     RowBox[{"L", ">", "0"}]}]}], "\n", 
   RowBox[{"(*", 
    RowBox[{"Momentum", " ", "values", " ", "in", " ", "NS", " ", "sector"}], 
    "*)"}], "\n", 
   RowBox[{
    RowBox[{"kValues", "[", 
     RowBox[{"L_", "?", "validLQ"}], "]"}], ":=", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"2", " ", "m"}], "+", "1"}], ")"}], " ", 
       RowBox[{"Pi", "/", "L"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"m", ",", "0", ",", 
        RowBox[{"L", "-", "1"}]}], "}"}]}], "]"}]}], "\n", "\n", 
   RowBox[{"(*", "Energy", "*)"}], "\n", 
   RowBox[{
    RowBox[{"eps", "[", 
     RowBox[{"J_", ",", "h_", ",", "k_"}], "]"}], ":=", 
    RowBox[{"Sqrt", "[", 
     RowBox[{
      RowBox[{"h", "^", "2"}], "+", 
      RowBox[{"J", "^", "2"}], "-", 
      RowBox[{"2", " ", "h", " ", "J", " ", 
       RowBox[{"Cos", "[", "k", "]"}]}]}], "]"}]}], "\n", 
   RowBox[{
    RowBox[{"E0Total", "[", 
     RowBox[{"J_", ",", "h_", ",", 
      RowBox[{"L_", "?", "validLQ"}]}], "]"}], ":=", 
    RowBox[{"-", 
     RowBox[{"Total", "[", 
      RowBox[{"eps", "[", 
       RowBox[{"J", ",", "h", ",", 
        RowBox[{"kValues", "[", "L", "]"}]}], "]"}], "]"}]}]}], "\n", 
   RowBox[{
    RowBox[{"E0PerSite", "[", 
     RowBox[{"J_", ",", "h_", ",", 
      RowBox[{"L_", "?", "validLQ"}]}], "]"}], ":=", 
    RowBox[{
     RowBox[{"E0Total", "[", 
      RowBox[{"J", ",", "h", ",", "L"}], "]"}], "/", "L"}]}], "\n", "\n", 
   RowBox[{"(*", 
    RowBox[{"Transverse", " ", "magnetization"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"Mx", "[", 
     RowBox[{"J_", ",", "h_", ",", 
      RowBox[{"L_", "?", "validLQ"}]}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"ks", "=", 
        RowBox[{"kValues", "[", "L", "]"}]}], "}"}], ",", 
      RowBox[{"Mean", "[", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"h", "-", 
          RowBox[{"J", " ", 
           RowBox[{"Cos", "[", "ks", "]"}]}]}], ")"}], "/", 
        RowBox[{"eps", "[", 
         RowBox[{"J", ",", "h", ",", "ks"}], "]"}]}], "]"}]}], "]"}]}], "\n", 
   "\n", 
   RowBox[{"(*", 
    RowBox[{
    "Longitudinal", " ", "correlator", " ", "via", " ", "Toeplitz", " ", 
     "Determinant"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"CorrelationZ", "[", 
     RowBox[{"J_", ",", "h_", ",", 
      RowBox[{"L_", "?", "validLQ"}], ",", "r_Integer"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"mat", ",", "G", ",", "ks", ",", "epsVals"}], "}"}], ",", "\n", 
      RowBox[{
       RowBox[{"ks", "=", 
        RowBox[{"kValues", "[", "L", "]"}]}], ";", "\n", 
       RowBox[{"epsVals", "=", 
        RowBox[{"eps", "[", 
         RowBox[{"J", ",", "h", ",", "ks"}], "]"}]}], ";", "\n", 
       RowBox[{
        RowBox[{"G", "[", "n_", "]"}], ":=", 
        RowBox[{
         RowBox[{"G", "[", "n", "]"}], "=", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"1", "/", "L"}], ")"}], " ", 
          RowBox[{"Re", "@", 
           RowBox[{"Total", "[", 
            RowBox[{
             RowBox[{"Exp", "[", 
              RowBox[{"I", " ", "ks", " ", "n"}], "]"}], " ", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"h", "-", 
                RowBox[{"J", " ", 
                 RowBox[{"Cos", "[", "ks", "]"}]}], "+", 
                RowBox[{"I", " ", "J", " ", 
                 RowBox[{"Sin", "[", "ks", "]"}]}]}], ")"}], "/", 
              "epsVals"}]}], "]"}]}]}]}]}], ";", "\n", 
       RowBox[{"mat", "=", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"G", "[", 
           RowBox[{"i", "-", "j", "+", "1"}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "1", ",", "r"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"j", ",", "1", ",", "r"}], "}"}]}], "]"}]}], ";", "\n", 
       RowBox[{"Re", "[", 
        RowBox[{"Det", "[", 
         RowBox[{"SetPrecision", "[", 
          RowBox[{"mat", ",", "50"}], "]"}], "]"}], "]"}]}]}], "\n", "]"}]}], 
   "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Staggered", " ", "half"}], "-", 
     RowBox[{"chain", " ", "correlator", " ", "and", " ", "magnetization"}]}],
     "*)"}], "\n", 
   RowBox[{
    RowBox[{"CpiHalf", "[", 
     RowBox[{"J_", ",", "h_", ",", 
      RowBox[{"L_", "?", "validLQ"}]}], "]"}], ":=", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"-", "1"}], ")"}], "^", 
      RowBox[{"(", 
       RowBox[{"L", "/", "2"}], ")"}]}], " ", 
     RowBox[{"CorrelationZ", "[", 
      RowBox[{"J", ",", "h", ",", "L", ",", 
       RowBox[{"L", "/", "2"}]}], "]"}]}]}], "\n", 
   RowBox[{
    RowBox[{"MzHalf", "[", 
     RowBox[{"J_", ",", "h_", ",", 
      RowBox[{"L_", "?", "validLQ"}]}], "]"}], ":=", 
    RowBox[{"Sqrt", "[", 
     RowBox[{"Abs", "[", 
      RowBox[{"CpiHalf", "[", 
       RowBox[{"J", ",", "h", ",", "L"}], "]"}], "]"}], "]"}]}], "\n", "\n", 
   RowBox[{"(*", 
    RowBox[{"thermodynamic", " ", "limits", " ", "for", " ", "benchmark"}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"E0PerSiteThermo", "[", 
     RowBox[{"J_", ",", "h_"}], "]"}], ":=", 
    RowBox[{"System`N", "[", 
     RowBox[{
      RowBox[{"-", 
       RowBox[{"(", 
        RowBox[{"1", "/", "Pi"}], ")"}]}], " ", 
      RowBox[{"NIntegrate", "[", 
       RowBox[{
        RowBox[{"Sqrt", "[", 
         RowBox[{
          RowBox[{"h", "^", "2"}], "+", 
          RowBox[{"J", "^", "2"}], "-", 
          RowBox[{"2", " ", "h", " ", "J", " ", 
           RowBox[{"Cos", "[", "k", "]"}]}]}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"k", ",", "0", ",", "Pi"}], "}"}]}], "]"}]}], "]"}]}], "\n", 
   
   RowBox[{
    RowBox[{"MxThermo", "[", 
     RowBox[{"J_", ",", "h_"}], "]"}], ":=", 
    RowBox[{"System`N", "[", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "/", "Pi"}], ")"}], " ", 
      RowBox[{"NIntegrate", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"h", "-", 
           RowBox[{"J", " ", 
            RowBox[{"Cos", "[", "k", "]"}]}]}], ")"}], "/", 
         RowBox[{"Sqrt", "[", 
          RowBox[{
           RowBox[{"h", "^", "2"}], "+", 
           RowBox[{"J", "^", "2"}], "-", 
           RowBox[{"2", " ", "h", " ", "J", " ", 
            RowBox[{"Cos", "[", "k", "]"}]}]}], "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"k", ",", "0", ",", "Pi"}], "}"}]}], "]"}]}], "]"}]}], "\n", 
   
   RowBox[{
    RowBox[{"MzStagThermo", "[", 
     RowBox[{"J_", ",", "h_"}], "]"}], ":=", 
    RowBox[{"Piecewise", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"1", "-", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"h", "/", "J"}], ")"}], "^", "2"}]}], ")"}], "^", 
          RowBox[{"(", 
           RowBox[{"1", "/", "8"}], ")"}]}], ",", 
         RowBox[{
          RowBox[{"h", "<", "J"}], "&&", 
          RowBox[{"J", ">", "0"}]}]}], "}"}], "}"}], ",", "0"}], 
     "]"}]}]}]}]], "Input",
 CellChangeTimes->{{3.982383826500966*^9, 3.982383862279351*^9}},
 CellLabel->"In[1]:=",ExpressionUUID->"b75f27c7-7dba-438d-9563-92f30300b9e5"]
}, Open  ]],

